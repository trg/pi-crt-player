#!/usr/bin/env bash
# crt-play — play a YouTube video (or search) on the CRT.
# Runs detached so it keeps playing after you disconnect SSH.
#
#   crt-play 'https://www.youtube.com/watch?v=...'   # play a URL
#   crt-play space oddity david bowie                 # search, play first hit
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "usage: crt-play <youtube-url | search terms>" >&2
  exit 1
fi

if [[ "$1" == http* ]]; then
  target="$1"
else
  echo "searching for: $*"
  vid="$(yt-dlp --default-search ytsearch --get-id "$*" 2>/dev/null | head -n1)"
  if [ -z "$vid" ]; then
    echo "no results for: $*" >&2
    exit 1
  fi
  target="https://www.youtube.com/watch?v=$vid"
fi

# Stop anything already playing so we don't fight over the display.
pkill -x mpv 2>/dev/null || true

# Detach from this SSH session so playback survives logout.
setsid mpv "$target" >/tmp/crt-play.log 2>&1 </dev/null &

echo "playing: $target"
echo "(log: /tmp/crt-play.log — run 'crt-stop' to stop)"
